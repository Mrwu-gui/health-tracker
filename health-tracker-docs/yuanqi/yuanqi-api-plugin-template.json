{
  "name": "健康管理小程序_API_模板",
  "baseUrl": "https://www.datewell.xyz",
  "auth": {
    "type": "bearer",
    "header": "Authorization",
    "tokenVar": "token",
    "valueFormat": "Bearer {{token}}"
  },
  "endpoints": [
    {
      "name": "新增提醒",
      "method": "POST",
      "path": "/api/reminder/add",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "userId": "{{userId}}",
        "title": "{{title}}",
        "type": "{{type}}",
        "content": "{{content}}",
        "remindTime": "{{remindTime}}"
      }
    },
    {
      "name": "新增目标",
      "method": "POST",
      "path": "/api/goal/add",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "userId": "{{userId}}",
        "goalType": "{{goalType}}",
        "targetValue": "{{targetValue}}",
        "currentValue": "{{currentValue}}",
        "period": "{{period}}"
      }
    },
    {
      "name": "新增用药",
      "method": "POST",
      "path": "/api/medication/add",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "userId": "{{userId}}",
        "drugName": "{{drugName}}",
        "dosage": "{{dosage}}",
        "frequency": "{{frequency}}",
        "remindTime": "{{remindTime}}",
        "startDate": "{{startDate}}"
      }
    },
    {
      "name": "新增家庭成员",
      "method": "POST",
      "path": "/api/family/add",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "userId": "{{userId}}",
        "name": "{{name}}",
        "relation": "{{relation}}",
        "age": "{{age}}",
        "conditionText": "{{conditionText}}"
      }
    }
  ]
}
